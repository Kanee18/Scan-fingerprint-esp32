rules_version = '2';

// ============================================================
//  Aturan Keamanan Firestore - Sistem Absensi Sidik Jari SMA
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper ----------
    function isSignedIn() {
      return request.auth != null;
    }

    // Ambil dokumen profil user yang sedang login
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return isSignedIn() ? userDoc().role : 'guest';
    }

    function isAdmin() {
      return role() == 'admin';
    }

    // Staf yang boleh menulis data absensi (admin, operator, wali kelas)
    function isStaff() {
      return role() in ['admin', 'operator', 'wali_kelas'];
    }

    // ---------- users ----------
    match /users/{uid} {
      // User boleh baca profilnya sendiri; admin baca semua
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Hanya admin yang boleh membuat/mengubah/menghapus akun & role
      allow write: if isAdmin();
    }

    // ---------- Master data (kelas, mapel, jadwal, pengaturan) ----------
    match /classes/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /subjects/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /teachers/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /schedules/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------- students ----------
    match /students/{id} {
      allow read: if isSignedIn();
      // Admin & operator boleh kelola siswa (operator perlu set fingerprintId saat enroll)
      allow write: if role() in ['admin', 'operator'];
    }

    // ---------- attendance (catatan absensi per jam pelajaran) ----------
    match /attendance/{id} {
      allow read: if isSignedIn();
      // Kiosk (operator), admin, dan wali kelas boleh mencatat/mengubah absensi
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ---------- audit log (opsional) ----------
    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
